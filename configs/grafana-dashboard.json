{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "BuckTooth Gateway",
  "uid": "bucktooth-gateway",
  "version": 1,
  "schemaVersion": 39,
  "tags": ["bucktooth"],
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Message Rate (in/out)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "rate(bucktooth_messages_total{direction=\"in\"}[1m])",
          "legendFormat": "inbound"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "rate(bucktooth_messages_total{direction=\"out\"}[1m])",
          "legendFormat": "outbound"
        }
      ]
    },
    {
      "id": 2,
      "title": "Message Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "histogram_quantile(0.50, rate(bucktooth_message_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "histogram_quantile(0.95, rate(bucktooth_message_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "histogram_quantile(0.99, rate(bucktooth_message_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 3,
      "title": "Token Usage (in/out)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "rate(bucktooth_tokens_total{direction=\"in\"}[1m])",
          "legendFormat": "input tokens/s"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "rate(bucktooth_tokens_total{direction=\"out\"}[1m])",
          "legendFormat": "output tokens/s"
        }
      ]
    },
    {
      "id": 4,
      "title": "Active Users",
      "type": "stat",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "bucktooth_active_users",
          "legendFormat": "active users"
        }
      ]
    }
  ]
}
